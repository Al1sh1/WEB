{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "./out-tsc/app",
        "types": []
    },
    "files": [
        "src/main.ts"
    ],
    "include": [
        "src/**/*.d.ts",
        "*.ts",
        "components/**/*.ts",
        "services/**/*.ts",
        "models/**/*.ts"
    ],
    "exclude": [
        "**/*.spec.ts",
        "app.spec.ts"
    ]
}